{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Helmor",
	"version": "1.5.7",
	"identifier": "ai.helmor.desktop",
	"build": {
		"beforeDevCommand": "bun x vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "node scripts/prepare-sidecar.mjs && bun run build && bun run build:web",
		"frontendDist": "../dist"
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["helmor", "helmor-dev"]
			}
		}
	},
	"app": {
		"windows": [
			{
				"title": "Helmor",
				"width": 1300,
				"height": 810,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 12,
					"y": 20
				},
				"hiddenTitle": true,
				"center": true,
				"backgroundColor": "#0E0E0E"
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": {
					"allow": ["**"]
				}
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"externalBin": [
			"../sidecar/dist/helmor-sidecar",
			"../knowledge-sidecar/dist/helmor-knowledge-sidecar",
			"./target/bundled/helmor-cli",
			"./target/bundled/helmor-web"
		],
		"resources": {
			"../sidecar/dist/vendor/": "vendor",
			"../dist-web/": "web-dist",
			"../.codex/skills/": "skills/codex",
			"../.claude/skills/": "skills/claude",
			"../.agents/skills/": "skills/agents"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns"
		],
		"macOS": {
			"entitlements": "Entitlements.plist"
		}
	}
}
